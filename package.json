{
  "name": "chroma-remote-mcp",
  "version": "1.0.2",
  "description": "ChromaDB Remote MCP Server with Streamable HTTP Transport",
  "type": "module",
  "main": "build/index.js",
  "mcpName": "io.github.meloncafe/chromadb-remote-mcp",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf build",
    "type-check": "tsc --noEmit",
    "test": "scripts/test.sh",
    "test:keep": "scripts/test.sh --no-cleanup",
    "test:unit": "jest --selectProjects unit",
    "test:unit:watch": "jest --selectProjects unit --watch",
    "test:unit:coverage": "jest --selectProjects unit --coverage",
    "test:integration": "jest --selectProjects integration",
    "test:integration:verbose": "jest --selectProjects integration --verbose",
    "test:all": "yarn test:unit:coverage && yarn test",
    "test:compatibility": "scripts/test-chromadb-compatibility.sh",
    "docker:build": "scripts/build.sh",
    "docker:build:local": "scripts/build.sh --platform linux/amd64 --load",
    "docker:push": "./scripts/build.sh --push"
  },
  "keywords": [
    "mcp",
    "chromadb",
    "remote-mcp",
    "streamable-http",
    "vector-database"
  ],
  "author": "Aether",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/meloncafe/chromadb-remote-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/meloncafe/chromadb-remote-mcp/issues"
  },
  "homepage": "https://github.com/meloncafe/chromadb-remote-mcp#readme",
  "dependencies": {
    "@chroma-core/default-embed": "^0.1.8",
    "@modelcontextprotocol/sdk": "^1.21.0",
    "chromadb": "^3.1.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "http-proxy-middleware": "^3.0.5"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "eslint": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "prettier": "^3.6.2"
  },
  "engines": {
    "node": ">=24.11.0",
    "yarn": ">=1.22.22"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
