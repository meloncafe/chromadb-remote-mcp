{
  "name": "chroma-remote-mcp",
  "version": "3.0.0",
  "description": "ChromaDB Remote MCP Server with Streamable HTTP Transport",
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "main": "build/index.js",
  "mcpName": "io.github.meloncafe/chromadb-remote-mcp",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf build",
    "type-check": "tsc --noEmit",
    "test": "scripts/test.sh",
    "test:keep": "scripts/test.sh --no-cleanup",
    "test:unit": "jest --selectProjects unit",
    "test:unit:watch": "jest --selectProjects unit --watch",
    "test:unit:coverage": "jest --selectProjects unit --coverage",
    "test:integration": "jest --selectProjects integration",
    "test:integration:verbose": "jest --selectProjects integration --verbose",
    "test:all": "yarn test:unit:coverage && yarn test",
    "test:compatibility": "scripts/test-chromadb-compatibility.sh",
    "docker:build": "scripts/build.sh",
    "docker:build:local": "scripts/build.sh --platform linux/amd64 --load",
    "docker:push": "./scripts/build.sh --push"
  },
  "keywords": [
    "mcp",
    "chromadb",
    "remote-mcp",
    "streamable-http",
    "vector-database"
  ],
  "author": "Aether",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/meloncafe/chromadb-remote-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/meloncafe/chromadb-remote-mcp/issues"
  },
  "homepage": "https://github.com/meloncafe/chromadb-remote-mcp#readme",
  "dependencies": {
    "@chroma-core/default-embed": "^0.1.9",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chromadb": "^3.4.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "http-proxy-middleware": "^4.1.1",
    "jose": "^6.2.3"
  },
  "resolutions": {
    "ip-address": "^10.2.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.15.0",
    "yarn": ">=4.14.1"
  },
  "dependenciesMeta": {
    "esbuild": {
      "built": true
    },
    "onnxruntime-node": {
      "built": true
    },
    "protobufjs": {
      "built": true
    },
    "sharp": {
      "built": true
    },
    "unrs-resolver": {
      "built": true
    }
  }
}
